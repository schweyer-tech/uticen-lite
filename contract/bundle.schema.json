{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://controlflow.dev/schemas/bundle/1.0",
  "title": "ControlFlow Bundle",
  "description": "Versioned cross-language import contract for a ControlFlow project bundle.",
  "type": "object",
  "required": ["schema_version", "project", "controls"],
  "properties": {
    "schema_version": {
      "const": "1.0",
      "description": "Bundle schema version — must be '1.0'."
    },
    "project": {
      "type": "object",
      "description": "Project-level metadata.",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable project name."
        },
        "framework": {
          "type": "string",
          "description": "Optional compliance framework (e.g. NIST 800-53)."
        },
        "system": {
          "type": "string",
          "description": "Optional target system or boundary name."
        }
      },
      "additionalProperties": true
    },
    "controls": {
      "type": "array",
      "description": "Array of control definitions with test code, workpapers, and run history.",
      "items": { "$ref": "#/$defs/control" }
    }
  },
  "additionalProperties": true,

  "$defs": {
    "framework_refs": {
      "type": "object",
      "description": "Framework reference tags (NIST, ISO, etc.).",
      "properties": {
        "nist": {
          "type": "array",
          "items": { "type": "string" },
          "description": "NIST control identifiers (e.g. AC-2)."
        },
        "extra": {
          "type": "object",
          "description": "Additional framework refs keyed by framework name.",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },

    "risk": {
      "type": "object",
      "description": "Risk linked to a control.",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "inherent_rating": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },

    "source": {
      "type": "object",
      "description": "Data source bound to a control (app data_sources shape + id).",
      "required": ["id", "type", "key_config", "column_mappings"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique source identifier."
        },
        "type": {
          "type": "string",
          "description": "Source type (e.g. file, s3, snowflake, rest)."
        },
        "key_config": {
          "type": "object",
          "description": "Row key derivation config.",
          "required": ["mode"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["auto", "single", "composite"]
            },
            "columns": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "column_mappings": {
          "type": "array",
          "description": "Column display/key mapping configuration.",
          "items": {
            "type": "object",
            "required": ["original_name", "display_name"],
            "properties": {
              "original_name": { "type": "string" },
              "display_name": { "type": "string" },
              "is_key": { "type": "boolean" },
              "include": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },

    "violation": {
      "type": "object",
      "description": "A single control violation (Violation.to_dict() shape).",
      "required": ["item_key", "description"],
      "properties": {
        "item_key": { "type": "string" },
        "description": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "details": { "type": "object" }
      },
      "additionalProperties": true
    },

    "provenance": {
      "type": "object",
      "description": "Source snapshot used in a run (SourceProvenance.to_dict() shape).",
      "required": ["source_id", "path", "sha256", "row_count"],
      "properties": {
        "source_id": { "type": "string" },
        "path": { "type": "string" },
        "sha256": { "type": "string" },
        "row_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },

    "run": {
      "type": "object",
      "description": "Run record (RunRecord.to_dict() shape).",
      "required": [
        "run_id",
        "executed_at",
        "passed",
        "failed",
        "total",
        "pass_rate",
        "summary",
        "details",
        "control_id",
        "provenance"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "description": "Deterministic 16-char hex identifier."
        },
        "executed_at": {
          "type": "string",
          "description": "ISO-8601 timestamp of execution."
        },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "total": {
          "type": "integer",
          "minimum": 0,
          "description": "Population size (maps to RunRecord.population_size)."
        },
        "pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "summary": { "type": "string" },
        "details": {
          "type": "object",
          "description": "Run details including violations list.",
          "required": ["violations"],
          "properties": {
            "violations": {
              "type": "array",
              "items": { "$ref": "#/$defs/violation" }
            }
          },
          "additionalProperties": true
        },
        "control_id": { "type": "string" },
        "provenance": {
          "type": "array",
          "items": { "$ref": "#/$defs/provenance" }
        }
      },
      "additionalProperties": true
    },

    "procedure": {
      "type": "object",
      "description": "A single test procedure within a workpaper (Procedure.to_dict() shape).",
      "required": ["title", "narrative", "test_code", "result"],
      "properties": {
        "code": { "type": "string" },
        "title": { "type": "string" },
        "assertion": { "type": "string" },
        "narrative": { "type": "string" },
        "test_code": { "type": "string" },
        "result": { "$ref": "#/$defs/run" }
      },
      "additionalProperties": true
    },

    "workpaper": {
      "type": "object",
      "description": "Audit workpaper (Workpaper.to_dict() shape).",
      "required": [
        "control_id",
        "title",
        "objective",
        "narrative",
        "framework_refs",
        "procedures",
        "generated_at"
      ],
      "properties": {
        "control_id": { "type": "string" },
        "title": { "type": "string" },
        "objective": { "type": "string" },
        "narrative": { "type": "string" },
        "framework_refs": { "$ref": "#/$defs/framework_refs" },
        "procedures": {
          "type": "array",
          "items": { "$ref": "#/$defs/procedure" }
        },
        "generated_at": { "type": "string" }
      },
      "additionalProperties": true
    },

    "control": {
      "type": "object",
      "description": "A control definition with embedded test code, workpaper, and run history.",
      "required": [
        "id",
        "title",
        "objective",
        "narrative",
        "framework_refs",
        "sources",
        "test_code",
        "workpaper",
        "runs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique slug identifier for the control."
        },
        "title": { "type": "string" },
        "objective": { "type": "string" },
        "narrative": { "type": "string" },
        "framework_refs": { "$ref": "#/$defs/framework_refs" },
        "risk": {
          "oneOf": [
            { "$ref": "#/$defs/risk" },
            { "type": "null" }
          ],
          "description": "Optional risk linked to this control."
        },
        "sources": {
          "type": "array",
          "description": "Data sources bound to this control.",
          "items": { "$ref": "#/$defs/source" }
        },
        "test_code": {
          "type": "string",
          "description": "Python test script source code."
        },
        "workpaper": { "$ref": "#/$defs/workpaper" },
        "runs": {
          "type": "array",
          "description": "Run history for this control.",
          "items": { "$ref": "#/$defs/run" }
        }
      },
      "additionalProperties": true
    }
  }
}
